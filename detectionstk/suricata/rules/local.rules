# ======================================================
# BASIC TELEMETRY (For validating the pipeline works)
# ======================================================
alert icmp any any -> $HOME_NET any (msg:"THESIS: ICMP traffic detected"; classtype:misc-activity; sid:1000001; rev:1;)
alert http any any -> $HOME_NET any (msg:"THESIS: HTTP traffic detected"; classtype:misc-activity; sid:1000002; rev:1;)


# ======================================================
# DNS SPOOFING DETECTION (Ettercap Attack Phase)
# ======================================================

# CRITICAL DETECTION: Alerts if a DNS response comes from an IP NOT in your DNS_SERVERS list
alert udp !$DNS_SERVERS 53 -> $HOME_NET any (msg:"THESIS: DNS spoofing detected - Response from non-authorized host"; app-layer-protocol:dns; flow:to_client; classtype:bad-unknown; sid:1000010; rev:1;)

alert dns any any -> any any (msg:"THESIS: DNS answer observed (possible spoofing)"; classtype:bad-unknown; sid:1000011; rev:3;)

# Alerts when a query for your specific lab domain is observed
alert dns any any -> any any (msg:"THESIS: DNS query for protected lab domain"; dns.query; content:"bank.lab"; nocase; classtype:policy-violation; sid:1000012; rev:1;)
alert http any any -> any any (msg:"THESIS: HTTP traffic detected"; sid:1000002; rev:1;)
alert portscan any any -> $HOME_NET any (msg:"THESIS: Portscan detected"; sid:1000100; rev:1;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"THESIS: Possible port scan - multiple SYN packets"; flags:S; threshold: type both, track by_src, count 20, seconds 10; sid:1000101; rev:1;)
